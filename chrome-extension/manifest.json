{
  "manifest_version": 3,
  "name": "Twitter Content Collector",
  "version": "1.0",
  "description": "Collect Twitter content for showcase website",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Twitter Content Collector"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"]
    }
  ]
} 